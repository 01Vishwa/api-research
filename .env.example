# ─── Required ────────────────────────────────────────────────────────────────
# Get free API key from GitHub Developer Settings
GITHUB_TOKEN=your_github_token_here

# ─── Strongly Recommended ────────────────────────────────────────────────────
# Get free API key at: https://app.tavily.com (1000 free searches/month)
TAVILY_API_KEY=your_tavily_api_key_here

# ─── Optional (Composio SDK) ─────────────────────────────────────────────────
# Get key at: https://app.composio.dev (free tier available)
# Required to use Composio's own search/fetch tools in the agent.
# Without this, the pipeline falls back to Tavily + httpx.
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_USER_ID=your_composio_user_id_here

# ─── Pipeline tuning (optional) ──────────────────────────────────────────────
BATCH_SIZE=10               # Concurrent apps researched at once
LLM_MODEL=openai/gpt-5
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
MAX_SEARCH_RESULTS=5
HTTP_TIMEOUT=20
MAX_RETRIES=3
LANGGRAPH_RECURSION=10
